unfix   NVT
undump  1112


# --------------- Equilibration in nve -----------------
reset_timestep  0
#velocity edge_left set  0.0 0.0 0.0 units box
#velocity edge_right set 0.0 0.0 0.0 units box
#fix 22 edge_left setforce 0.0 0.0 0.0
#fix 23 edge_right setforce 0.0 0.0 0.0

#run 1
#unfix 22
#unfix 23

fix 11 hot  langevin 330.0 330.0 0.5 48279  tally yes
fix 12 cold langevin 270.0 270.0 0.5 48279  tally yes

fix 	NVE mid nve

#fix 11 hot temp/berendsen 350.0 350.0 0.0050
#fix_modify 11 energy yes

#fix 12 cold temp/berendsen 250.0 250.0 0.0050
#fix_modify 12 energy yes

#fix 11 hot heat 1 1.0
#fix 12 cold heat 1 -1.0

thermo_style    custom step temp press pe ke lx ly lz f_11 f_12
thermo	$d
thermo	200000


run 	3000000
